<?xml version="1.0"?>
<ruleset name="Starter Theme">
    <description>WordPress coding standards for starter-theme.</description>

    <file>.</file>

    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>

    <rule ref="WordPress">
        <!-- Allow short array syntax [] -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <!-- Allow short ternary / null coalescing -->
        <exclude name="WordPress.PHP.DisallowShortTernary"/>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="starter-theme"/>
        </properties>
    </rule>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array" value="st_,StarterTheme"/>
        </properties>
    </rule>

    <config name="minimum_supported_wp_version" value="6.3"/>
    <config name="testVersion" value="8.1-"/>
</ruleset>
