{
  "name": "starter-theme",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node -e \"require('fs').writeFileSync('.vite-dev', '')\"",
    "dev": "vite",
    "postdev": "node -e \"try{require('fs').unlinkSync('.vite-dev')}catch(e){}\"",
    "build": "vite build",
    "postbuild": "node -e \"try{require('fs').unlinkSync('.vite-dev')}catch(e){}\"",
    "preview": "vite preview",
    "lint:js": "eslint assets/src/js",
    "lint:js:fix": "eslint assets/src/js --fix",
    "lint:php": "php -l $(find . -name '*.php' -not -path '*/node_modules/*' -not -path '*/dist/*' -not -path '*/vendor/*')",
    "lint": "npm run lint:js && npm run lint:php",
    "format": "prettier --write \"assets/src/**/*.{js,css,json}\"",
    "format:check": "prettier --check \"assets/src/**/*.{js,css,json}\"",
    "makepot": "node scripts/makepot.cjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "assets/src/js/**/*.js": [
      "prettier --write",
      "eslint"
    ],
    "assets/src/css/**/*.css": "prettier --write",
    "**/*.php": "php -l"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@wordpress/dom-ready": "^4.46.0",
    "@wordpress/hooks": "^4.46.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wp-pot": "^1.10.2"
  },
  "dependencies": {
    "swiper": "^12.1.4"
  }
}
