# Deployment configuration
# Copy this file to .env for local reference — never commit .env
# These values go into GitHub repo Settings → Secrets and variables → Actions

# --- Staging ---
STAGING_SSH_HOST=staging.example.com
STAGING_SSH_USER=deploy
STAGING_SSH_PORT=22
# STAGING_SSH_KEY — paste full private key content (use ed25519: ssh-keygen -t ed25519)
STAGING_DEPLOY_PATH=/var/www/vhosts/domain.com/httpdocs/wp-content/themes/starter-theme

# --- Production ---
PRODUCTION_SSH_HOST=example.com
PRODUCTION_SSH_USER=deploy
PRODUCTION_SSH_PORT=22
# PRODUCTION_SSH_KEY — separate key from staging recommended
PRODUCTION_DEPLOY_PATH=/var/www/vhosts/domain.com/httpdocs/wp-content/themes/starter-theme

# --- Post-deploy (optional) ---
# Path to WP-CLI on the server, used to flush cache after deploy
# WP_CLI_PATH=/usr/local/bin/wp
# WP_ROOT=/var/www/vhosts/domain.com/httpdocs
