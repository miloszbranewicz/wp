{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": false,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "background": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [],
      "gradients": [],
      "link": true,
      "text": true,
      "palette": [
        { "slug": "primary",      "color": "#2563eb", "name": "Primary" },
        { "slug": "primary-dark", "color": "#1d4ed8", "name": "Primary Dark" },
        { "slug": "secondary",    "color": "#7c3aed", "name": "Secondary" },
        { "slug": "neutral-900",  "color": "#111827", "name": "Neutral 900" },
        { "slug": "neutral-600",  "color": "#4b5563", "name": "Neutral 600" },
        { "slug": "neutral-100",  "color": "#f3f4f6", "name": "Neutral 100" },
        { "slug": "white",        "color": "#ffffff", "name": "White" },
        { "slug": "black",        "color": "#000000", "name": "Black" }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "dropCap": false,
      "fluid": true,
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",  "name": "XS"   },
        { "slug": "sm",   "size": "0.875rem", "name": "SM"   },
        { "slug": "base", "size": "1rem",     "name": "Base" },
        { "slug": "lg",   "size": "1.125rem", "name": "LG"   },
        { "slug": "xl",   "size": "1.25rem",  "name": "XL"   },
        { "slug": "2xl",  "size": "1.5rem",   "name": "2XL"  },
        { "slug": "3xl",  "size": "1.875rem", "name": "3XL"  },
        { "slug": "4xl",  "size": "2.25rem",  "name": "4XL"  },
        { "slug": "5xl",  "size": "3rem",     "name": "5XL"  }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "margin": true,
      "padding": true,
      "units": ["px", "rem", "%", "vw", "vh"]
    },
    "layout": {
      "contentSize": "768px",
      "wideSize": "1280px"
    },
    "blocks": {
      "core/image": {
        "lightbox": { "allowEditing": false }
      },
      "core/button": {
        "color": { "background": true, "text": true }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--neutral-900)"
    },
    "typography": {
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "1.5rem"
    }
  }
}
